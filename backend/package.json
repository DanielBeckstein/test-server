{
  "name": "quantos-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --format esm --out-dir dist --clean",
    "start": "node dist/main.js",
    "test": "node --import tsx --test 'tests/**/*.test.ts'",
    "test:watch": "node --import tsx --test --watch 'tests/**/*.test.ts'"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.13.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
